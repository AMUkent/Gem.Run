using UnityEngine;

/// <summary>
/// A moving hazard that patrols between two points and deals damage
/// when it touches the player.
///
/// Setup:
///   • Add a Collider set to Is Trigger = true.
///   • Tag this GameObject "Hazard".
///   • Set pointA and pointB in the Inspector (world positions).
/// </summary>
public class Hazard : MonoBehaviour
{
    [Header("Patrol Points")]
    [Tooltip("First patrol point (world position)")]
    public Transform pointA;

    [Tooltip("Second patrol point (world position)")]
    public Transform pointB;

    [Header("Movement")]
    [Tooltip("Movement speed in metres per second")]
    public float speed = 4f;

    [Header("Damage")]
    [Tooltip("Damage dealt to the player on contact")]
    public int damage = 1;

    [Tooltip("Seconds the player is invincible after being hit (prevents rapid damage)")]
    public float hitCooldown = 1f;

    // ── Private State ───────────────────────────────────────────────────────
    private Transform _target;
    private float _cooldownTimer;

    // ── Unity Lifecycle ─────────────────────────────────────────────────────
    private void Start()
    {
        if (pointA == null || pointB == null)
        {
            Debug.LogWarning($"[Hazard] '{name}' is missing patrol points! Please assign pointA and pointB.");
            enabled = false;
            return;
        }

        _target = pointB;
    }

    private void Update()
    {
        if (pointA == null || pointB == null) return;

        // Move toward current target
        transform.position = Vector3.MoveTowards(transform.position, _target.position, speed * Time.deltaTime);

        // Swap target when close enough
        if (Vector3.Distance(transform.position, _target.position) < 0.05f)
            _target = _target == pointA ? pointB : pointA;

        // Tick down hit cooldown
        if (_cooldownTimer > 0f)
            _cooldownTimer -= Time.deltaTime;
    }

    private void OnTriggerEnter(Collider other)
    {
        TryDamagePlayer(other);
    }

    // Some setups also benefit from OnTriggerStay for slower hazards
    private void OnTriggerStay(Collider other)
    {
        TryDamagePlayer(other);
    }

    // ── Private Methods ─────────────────────────────────────────────────────
    private void TryDamagePlayer(Collider other)
    {
        if (_cooldownTimer > 0f) return;
        if (!other.CompareTag("Player")) return;

        GameManager.Instance.OnPlayerDamaged(damage);
        _cooldownTimer = hitCooldown;
    }

#if UNITY_EDITOR
    // Draw patrol line in the Scene view for easy placement
    private void OnDrawGizmos()
    {
        if (pointA == null || pointB == null) return;
        Gizmos.color = Color.red;
        Gizmos.DrawLine(pointA.position, pointB.position);
        Gizmos.DrawWireSphere(pointA.position, 0.2f);
        Gizmos.DrawWireSphere(pointB.position, 0.2f);
    }
#endif
}
